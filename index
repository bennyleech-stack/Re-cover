<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Re:Cover</title>
    <style>
        :root { --mint: #A8E6C3; --rose: #F2A7B8; --bg: #F0F2F0; --text: #2D3A30; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; margin: 0; padding: 0; }
        body { font-family: sans-serif; background: var(--bg); color: var(--text); height: 100vh; display: flex; flex-direction: column; }

        header { background: white; padding: 15px; text-align: center; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        main { flex: 1; overflow-y: auto; padding: 15px; padding-bottom: 100px; }
        
        .card { background: white; border-radius: 20px; padding: 20px; margin-bottom: 15px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .mode-rest { border: 5px solid var(--rose); }
        .mode-active { border: 5px solid var(--mint); }

        .nav { position: fixed; bottom: 0; width: 100%; height: 80px; background: white; display: flex; border-top: 1px solid #ddd; z-index: 100; }
        .tab { flex: 1; border: none; background: none; font-size: 14px; font-weight: bold; color: #888; display: flex; flex-direction: column; align-items: center; justify-content: center; }
        .tab.active { color: var(--text); }
        .tab span { font-size: 24px; margin-bottom: 4px; }

        .btn { width: 100%; padding: 15px; border-radius: 15px; border: none; background: var(--mint); font-weight: bold; font-size: 16px; margin-top: 10px; }
        .row { display: flex; align-items: center; justify-content: space-between; margin-top: 10px; background: #f9f9f9; padding: 10px; border-radius: 10px; }
        .c-btn { width: 40px; height: 40px; border-radius: 50%; border: 1px solid #ccc; background: white; font-size: 20px; }
        
        .hidden { display: none; }
        input[type=range] { width: 100%; margin: 15px 0; }
    </style>
</head>
<body>

<header><h1>🌸 Re:Cover</h1></header>

<main id="content">
    <section id="h-pg">
        <div id="m-card" class="card mode-active">
            <h2 id="h-title">Daily Check-In</h2>
            <p>Fatigue Level (1-10):</p>
            <input type="range" id="f-slider" min="1" max="10" value="5">
            <button class="btn" onclick="setMode()">Update My Day</button>
        </div>
        <div class="card">
            <h3>Today's Focus</h3>
            <p id="f-msg">Check in above to see your plan.</p>
        </div>
    </section>

    <section id="m-pg" class="hidden">
        <div class="card">
            <h3>Stretches</h3>
            <p>• Shoulder Rolls (10x)<br>• Wall Crawls (5x)<br>• Doorway Lean</p>
        </div>
        <div id="walk-box" class="card">
            <div class="row">
                <span>Walk (Mins)</span>
                <button class="c-btn" onclick="add('walk',-5)">-</button>
                <b id="v-walk">0</b>
                <button class="c-btn" onclick="add('walk',5)">+</button>
            </div>
        </div>
    </section>

    <section id="f-pg" class="hidden">
        <div class="card">
            <div class="row">
                <span>Water (Glasses)</span>
                <button class="c-btn" onclick="add('water',-1)">-</button>
                <b id="v-water">0</b>
                <button class="c-btn" onclick="add('water',1)">+</button>
            </div>
        </div>
        <div class="card">
            <div class="row">
                <span>Protein Hits</span>
                <button class="c-btn" onclick="add('prot',-1)">-</button>
                <b id="v-prot">0</b>
                <button class="c-btn" onclick="add('prot',1)">+</button>
            </div>
        </div>
    </section>
</main>

<nav class="nav">
    <button class="tab active" onclick="nav('h-pg', this)"><span>🏠</span>Home</button>
    <button class="tab" onclick="nav('m-pg', this)"><span>💪</span>Moves</button>
    <button class="tab" onclick="nav('f-pg', this)"><span>🥗</span>Fuel</button>
</nav>

<script>
    let d = { fatigue: 5, walk: 0, water: 0, prot: 0 };

    function nav(id, b) {
        document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
        document.getElementById(id).classList.remove('hidden');
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        b.classList.add('active');
    }

    function setMode() {
        let f = document.getElementById('f-slider').value;
        let c = document.getElementById('m-card');
        let m = document.getElementById('f-msg');
        let w = document.getElementById('walk-box');
        
        if (f >= 8) {
            c.className = "card mode-rest";
            m.innerHTML = "<b>Rest Mode:</b> Your liver needs a break. Skip the walk, focus on water.";
            w.classList.add('hidden');
        } else {
            c.className = "card mode-active";
            m.innerHTML = "<b>Active Mode:</b> Energy is good! Try your stretches and a short walk.";
            w.classList.remove('hidden');
        }
    }

    function add(k, n) {
        d[k] = Math.max(0, d[k] + n);
        document.getElementById('v-' + k).innerText = d[k];
    }
</script>
</body>
</html>
